---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { PromptEditor } from '../../../components/PromptEditor';
import { getPromptById, listCatalogs, listPromptVersions } from '../../../lib/server/api';

if (!Astro.locals.user) {
  return Astro.redirect('/login');
}

const promptId = Astro.params.promptId;
if (!promptId) {
  return Astro.redirect('/');
}

const [prompt, catalogs, versions] = await Promise.all([
  getPromptById(Astro.locals.db, Astro.locals.user.id, promptId),
  listCatalogs(Astro.locals.db, Astro.locals.user.id, true),
  listPromptVersions(Astro.locals.db, Astro.locals.user.id, promptId),
]);

if (!prompt) {
  return Astro.redirect('/');
}
---

<BaseLayout title={`${prompt.title} | OpenCheats`} fullWidth>
  <PromptEditor
    client:load
    mode="edit"
    promptId={prompt.id}
    initialTitle={prompt.title}
    initialDocument={prompt.document}
    initialCurrentVersion={prompt.current_version}
    initialVersions={versions}
    catalogs={catalogs}
  />
</BaseLayout>
