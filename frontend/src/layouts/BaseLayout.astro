---
import '../styles/global.css';
import { UserRound } from 'lucide-preact';
import { SignOutButton } from '../components/SignOutButton';

const { title = 'OpenCheats', authPage = false, fullWidth = false } = Astro.props;
const user = Astro.locals.user;
const currentPath = new URL(Astro.request.url).pathname;

const navItems = user
  ? [
      { href: '/', label: 'Prompts' },
      { href: '/playground', label: 'Playground' },
      { href: '/catalogs', label: 'Catalogs' },
    ]
  : [];

function isActive(href: string) {
  if (href === '/') {
    return currentPath === '/' || currentPath.startsWith('/prompts');
  }

  return currentPath.startsWith(href);
}
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="brand">
          <span class="brand-mark">OC</span>
          OpenCheats
        </a>

        {navItems.length > 0 ? (
          <nav class="nav-links header-nav-center" aria-label="Primary">
            {navItems.map((item) => (
              <a href={item.href} class:list={['nav-link', isActive(item.href) && 'active']}>
                {item.label}
              </a>
            ))}
          </nav>
        ) : (
          <div class="header-nav-spacer" aria-hidden="true" />
        )}

        {user ? (
          <details class="user-menu">
            <summary class="user-menu-trigger" aria-label="Account menu">
              <span class="user-menu-icon" aria-hidden="true">
                <UserRound />
              </span>
            </summary>
            <div class="user-menu-panel">
              <p class="user-menu-email">{user.email}</p>
              <a href="/settings/providers" class="btn-secondary user-menu-link">AI Models</a>
              <SignOutButton client:load className="user-menu-signout" />
            </div>
          </details>
        ) : !authPage ? (
          <a href="/login" class="nav-cta">
            Login
          </a>
        ) : (
          <div class="header-nav-spacer" aria-hidden="true" />
        )}
      </div>
    </header>

    <main class:list={['page-shell', authPage && 'page-shell-auth', fullWidth && 'page-shell-full']}>
      {fullWidth || authPage ? (
        <slot />
      ) : (
        <div class="page-shell-inner">
          <slot />
        </div>
      )}
    </main>

    <script>
      document.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof Node)) {
          return;
        }

        document.querySelectorAll('.user-menu[open]').forEach((menu) => {
          if (menu.contains(target)) {
            return;
          }

          menu.removeAttribute('open');
        });
      });
    </script>
  </body>
</html>
